<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vips.pharma.controller.LoginController"
      styleClass="login-root"
      stylesheets="@../css/style.css">

    <!-- LEFT: yellow column -->
    <VBox HBox.hgrow="NEVER" prefWidth="440" minWidth="380" maxWidth="480"
          styleClass="login-left-stack" alignment="TOP_CENTER" spacing="0">

        <!-- TOP: brand/logo header — full width purple strip -->
        <VBox fx:id="loginHeader" styleClass="login-right-header"
              alignment="CENTER" spacing="6" fillWidth="true" maxWidth="Infinity">
            <Label fx:id="lblLogoEmoji" text="💊" styleClass="login-logo-emoji"/>
            <Label text="VI-PS PHARMA" styleClass="login-title"/>
            <Label text="Veda, Trust Us With Your Healthcare" styleClass="login-subtitle"/>
        </VBox>

        <!-- GAP between brand and card -->
        <Region prefHeight="32"/>

        <!-- WHITE CARD: sign in panel -->
        <VBox styleClass="login-right-panel" alignment="TOP_CENTER" spacing="0"
              maxWidth="392" minWidth="360">
            <VBox.margin><Insets left="24" right="24"/></VBox.margin>

            <!-- Card purple header: Sign In -->
            <HBox styleClass="login-card-header" alignment="CENTER_LEFT" maxWidth="Infinity">
                <Label text="Sign In to Continue" styleClass="login-card-title"/>
            </HBox>

            <!-- White form body -->
            <VBox styleClass="login-form-area" spacing="14" alignment="CENTER_LEFT">
                <padding><Insets top="20" left="24" right="24" bottom="20"/></padding>

                <Label text="Username" styleClass="field-label"/>
                <TextField fx:id="tfUsername" promptText="Enter username"
                           styleClass="search-field" maxWidth="Infinity"/>

                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="pfPassword" promptText="Enter password"
                               styleClass="search-field" maxWidth="Infinity"/>

                <Label fx:id="lblError" text="" styleClass="login-error"
                       wrapText="true" maxWidth="Infinity"/>

                <Button fx:id="btnLogin" text="LOGIN" onAction="#handleLogin"
                        styleClass="btn-login" maxWidth="Infinity"/>
                <Button text="Exit" onAction="#handleExit"
                        styleClass="btn-exit" maxWidth="Infinity"/>
            </VBox>

            <!-- Purple footer bar -->
            <HBox styleClass="login-footer-bar" alignment="CENTER" maxWidth="Infinity">
                <padding><Insets top="8" bottom="8"/></padding>

            </HBox>
        </VBox>

    </VBox>

    <!-- RIGHT: background image -->
    <StackPane fx:id="leftPanel" styleClass="login-left-panel"
               HBox.hgrow="ALWAYS" maxWidth="Infinity">
        <ImageView fx:id="ivBgImage"
                   preserveRatio="false" smooth="true"
                   fitWidth="9999" fitHeight="9999"/>
        <VBox styleClass="login-left-overlay" alignment="BOTTOM_LEFT" mouseTransparent="true">
            <padding><Insets bottom="48" left="48"/></padding>
            <Label text="VI-PS PHARMA" styleClass="login-brand-title"/>
            <Label text="Veda, Trust Us With Your Healthcare" styleClass="login-brand-sub"/>
        </VBox>
    </StackPane>

</HBox>
