<?xml version="1.0" encoding="UTF-8"?>
<!--
    ═══════════════════════════════════════════════════════════════
    RECEIPT REPORT — receipt.jrxml
    Data source: XML file written by XmlDataWriter.writeReceiptXml()

    XPath pipeline:
      selectExpression = "/data/receipt/items/item"   ← iterates line items
      Parameters come from /data/receipt/* via XPath expressions.

    Fields map directly to XML child-tag names under each <item>.
    ═══════════════════════════════════════════════════════════════
-->
<jasperReport
        xmlns="http://jasperreports.sourceforge.net/jasperreports"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
            http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
        name="Receipt"
        pageWidth="400"
        pageHeight="700"
        columnWidth="360"
        leftMargin="20"
        rightMargin="20"
        topMargin="20"
        bottomMargin="20">

    <!--
        PARAMETERS — populated from the XML file by ReportGenerator
        using JRXmlDataSource.getSubDataSource() + explicit parameter map.
        Values are read with XPath from the <receipt> header node.
    -->
    <parameter name="LOGO_IMAGE"  class="java.lang.String"/>
    <parameter name="receiptId"   class="java.lang.String"/>
    <parameter name="dateTime"    class="java.lang.String"/>
    <parameter name="processedBy" class="java.lang.String"/>
    <parameter name="grandTotal"  class="java.lang.String"/>

    <!--
        FIELDS — each <item> child tag in the XML becomes a field.
        JRXmlDataSource maps field name → XPath "fieldName" (relative).
    -->
    <field name="medName"            class="java.lang.String"/>
    <field name="quantity"           class="java.lang.String"/>
    <field name="unitPriceFormatted" class="java.lang.String"/>
    <field name="totalFormatted"     class="java.lang.String"/>

    <!-- ── TITLE BAND — receipt header ─────────────────────────────── -->
    <title>
        <band height="180">
            <!-- Logo (shown only when logo file exists) -->
            <image onErrorType="Blank" hAlign="Center">
                <reportElement x="0" y="0" width="360" height="60">
                    <printWhenExpression><![CDATA[$P{LOGO_IMAGE} != null && !$P{LOGO_IMAGE}.isEmpty()]]></printWhenExpression>
                </reportElement>
                <imageExpression><![CDATA[$P{LOGO_IMAGE}]]></imageExpression>
            </image>

            <!-- Pharmacy name -->
            <staticText>
                <reportElement x="0" y="60" width="360" height="30"/>
                <textElement textAlignment="Center">
                    <font fontName="DejaVu Sans" size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[VI-PS PHARMA]]></text>
            </staticText>

            <!-- Sub-title -->
            <staticText>
                <reportElement x="0" y="92" width="360" height="18"/>
                <textElement textAlignment="Center">
                    <font fontName="DejaVu Sans" size="10"/>
                </textElement>
                <text><![CDATA[OFFICIAL RECEIPT]]></text>
            </staticText>

            <!-- Divider -->
            <line>
                <reportElement x="0" y="114" width="360" height="1"/>
            </line>

            <!-- Receipt # label + value -->
            <staticText>
                <reportElement x="0" y="122" width="120" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9"/></textElement>
                <text><![CDATA[Receipt #:]]></text>
            </staticText>
            <textField>
                <reportElement x="120" y="122" width="240" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{receiptId}]]></textFieldExpression>
            </textField>

            <!-- Date/time label + value -->
            <staticText>
                <reportElement x="0" y="140" width="120" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9"/></textElement>
                <text><![CDATA[Date/Time:]]></text>
            </staticText>
            <textField>
                <reportElement x="120" y="140" width="240" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{dateTime}]]></textFieldExpression>
            </textField>

            <!-- Processed by label + value -->
            <staticText>
                <reportElement x="0" y="158" width="120" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9"/></textElement>
                <text><![CDATA[Processed by:]]></text>
            </staticText>
            <textField>
                <reportElement x="120" y="158" width="240" height="16"/>
                <textElement><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{processedBy}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="176" width="360" height="1"/>
            </line>
        </band>
    </title>

    <!-- ── COLUMN HEADER — table headings ──────────────────────────── -->
    <columnHeader>
        <band height="22">
            <staticText>
                <reportElement x="0"   y="2" width="170" height="18"/>
                <textElement><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <text><![CDATA[MEDICINE]]></text>
            </staticText>
            <staticText>
                <reportElement x="170" y="2" width="50"  height="18"/>
                <textElement textAlignment="Center"><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <text><![CDATA[QTY]]></text>
            </staticText>
            <staticText>
                <reportElement x="220" y="2" width="70"  height="18"/>
                <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <text><![CDATA[UNIT PRICE]]></text>
            </staticText>
            <staticText>
                <reportElement x="290" y="2" width="70"  height="18"/>
                <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <text><![CDATA[TOTAL]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="20" width="360" height="1"/>
            </line>
        </band>
    </columnHeader>

    <!-- ── DETAIL BAND — one row per <item> in the XML ─────────────── -->
    <detail>
        <band height="20">
            <textField isStretchWithOverflow="true">
                <reportElement x="0"   y="1" width="170" height="18"/>
                <textElement><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{medName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="170" y="1" width="50"  height="18"/>
                <textElement textAlignment="Center"><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{quantity}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="220" y="1" width="70"  height="18"/>
                <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{unitPriceFormatted}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="290" y="1" width="70"  height="18"/>
                <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{totalFormatted}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- ── SUMMARY BAND — grand total + footer ─────────────────────── -->
    <summary>
        <band height="80">
            <line>
                <reportElement x="0" y="4" width="360" height="1"/>
            </line>
            <staticText>
                <reportElement x="0"   y="12" width="240" height="22"/>
                <textElement><font fontName="DejaVu Sans" size="13" isBold="true"/></textElement>
                <text><![CDATA[GRAND TOTAL]]></text>
            </staticText>
            <textField>
                <reportElement x="240" y="12" width="120" height="22"/>
                <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="13" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{grandTotal}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="38" width="360" height="1"/>
            </line>
            <staticText>
                <reportElement x="0" y="48" width="360" height="16"/>
                <textElement textAlignment="Center"><font fontName="DejaVu Sans" size="9"/></textElement>
                <text><![CDATA[Thank you for your purchase!]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="64" width="360" height="14"/>
                <textElement textAlignment="Center"><font fontName="DejaVu Sans" size="8"/></textElement>
                <text><![CDATA[Veda, Trust Us With Your Healthcare]]></text>
            </staticText>
        </band>
    </summary>

</jasperReport>
