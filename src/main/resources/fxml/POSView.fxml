<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vips.pharma.controller.POSController"
      spacing="16" styleClass="view-pane">
    <padding><Insets top="24" left="24" right="24" bottom="24"/></padding>

    <Label text="Point of Sale" styleClass="page-title"/>

    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- ── LEFT: Select medicine ── -->
        <VBox spacing="0" prefWidth="300" styleClass="card">
            <Label text="Select Medicine" styleClass="card-title"/>
            <VBox spacing="12" VBox.vgrow="ALWAYS">
                <padding><Insets top="14" left="16" right="16" bottom="16"/></padding>

                <TextField fx:id="tfSearch" promptText="🔍  Search medicine…" styleClass="search-field"/>

                <ListView fx:id="medicineList" VBox.vgrow="ALWAYS" prefHeight="240" styleClass="medicine-list"/>

                <GridPane hgap="12" vgap="8">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    <Label text="Selected:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="lblSelected" text="—" styleClass="value-label"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="Unit Price:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="lblPrice" text="₱0.00" styleClass="value-label"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="In Stock:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="lblStock" text="0" styleClass="value-label"
                           GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                </GridPane>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Quantity:"/>
                    <Spinner fx:id="spinQty" prefWidth="90" min="1" max="9999" initialValue="1"/>
                    <Label fx:id="lblSubtotal" text="₱0.00" styleClass="amount-label"/>
                </HBox>

                <Button fx:id="btnAddToCart" text="➕  Add to Cart" onAction="#handleAddToCart"
                        styleClass="btn-primary" maxWidth="Infinity"/>
            </VBox>
        </VBox>

        <!-- ── RIGHT: Cart & Checkout ── -->
        <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="card">
            <Label text="Shopping Cart" styleClass="card-title"/>
            <VBox spacing="12" VBox.vgrow="ALWAYS">
                <padding><Insets top="14" left="16" right="16" bottom="16"/></padding>

                <TableView fx:id="cartTable" VBox.vgrow="ALWAYS" styleClass="medicine-list">
                    <columns>
                        <TableColumn fx:id="colName"  text="Medicine"   prefWidth="220"/>
                        <TableColumn fx:id="colQty"   text="Qty"        prefWidth="60"/>
                        <TableColumn fx:id="colPrice" text="Unit Price" prefWidth="100"/>
                        <TableColumn fx:id="colTotal" text="Total"      prefWidth="100"/>
                    </columns>
                    <placeholder><Label text="Cart is empty — add medicines from the left panel"/></placeholder>
                </TableView>

                <Separator/>

                <Label fx:id="lblTotal" text="TOTAL: ₱0.00" styleClass="total-label"/>

                <HBox spacing="10">
                    <Button text="✔  SELL" onAction="#processSale"
                            styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="🗑  Clear Cart" onAction="#clearCart"
                            styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>

                <Button text="🖨  Print Last Receipt" onAction="#printLastReceipt"
                        styleClass="btn-outline" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </HBox>
</VBox>
