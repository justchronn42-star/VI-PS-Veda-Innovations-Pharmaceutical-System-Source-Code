<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vips.pharma.controller.UserManagementController"
      spacing="16" styleClass="view-pane">
    <padding><Insets top="24" left="24" right="24" bottom="24"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="User Management" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <Label text="🔒 Admin Only" style="-fx-text-fill:#e74c3c; -fx-font-weight:bold; -fx-font-size:12px;"/>
        <Button text="＋  Add User" onAction="#showAddDialog" styleClass="btn-primary"/>
    </HBox>

    <VBox styleClass="white-panel" VBox.vgrow="ALWAYS" spacing="0">
        <TableView fx:id="userTable" VBox.vgrow="ALWAYS" styleClass="data-table">
            <columns>
                <TableColumn fx:id="colId"       text="#"        prefWidth="50"/>
                <TableColumn fx:id="colUsername" text="Username" prefWidth="200"/>
                <TableColumn fx:id="colRole"     text="Role"     prefWidth="160"/>
                <TableColumn fx:id="colStatus"   text="Status"   prefWidth="120"/>
                <TableColumn fx:id="colActions"  text="Actions"  prefWidth="200"/>
            </columns>
            <placeholder>
                <Label text="No users found." style="-fx-text-fill:#888;"/>
            </placeholder>
        </TableView>

        <HBox styleClass="summary-bar" spacing="30" alignment="CENTER_LEFT">
            <padding><Insets top="8" left="12" right="12" bottom="8"/></padding>
            <Label fx:id="lblCount" text="Total Users: 0"/>
            <Label text="⚠ You cannot edit or delete your own account."
                   style="-fx-text-fill:#e67e22; -fx-font-size:11px;"/>
        </HBox>
    </VBox>
</VBox>
