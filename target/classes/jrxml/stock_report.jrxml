<?xml version="1.0" encoding="UTF-8"?>
<!--
    ═══════════════════════════════════════════════════════════════
    STOCK INVENTORY REPORT — stock_report.jrxml
    Data source: XML written by XmlDataWriter.writeStockXml()

    selectExpression="/data/medicine" iterates every <medicine>
    in the XML file.  The <meta> node values are passed in as
    parameters by ReportGenerator before filling.
    ═══════════════════════════════════════════════════════════════
-->
<jasperReport
        xmlns="http://jasperreports.sourceforge.net/jasperreports"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
            http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
        name="StockReport"
        pageWidth="595"
        pageHeight="842"
        columnWidth="555"
        leftMargin="20"
        rightMargin="20"
        topMargin="20"
        bottomMargin="20">

    <!--
        Conditional style: red + bold when lowStock == "true"
    -->
    <style name="LowStockStyle" isDefault="false" forecolor="#000000">
        <conditionalStyle>
            <conditionExpression>
                <![CDATA["true".equals($F{lowStock})]]>
            </conditionExpression>
            <style forecolor="#CC0000" isBold="true"/>
        </conditionalStyle>
    </style>

        <!-- Metadata parameters extracted from <meta> node -->
    <parameter name="LOGO_IMAGE"    class="java.lang.String"/>
    <parameter name="reportDate"    class="java.lang.String"/>
    <parameter name="totalItems"    class="java.lang.String"/>
    <parameter name="lowStockCount" class="java.lang.String"/>

    <!--
        Fields — each maps to a child tag of <medicine> in the XML.
        "lowStock" is the flag written as "true"/"false" by XmlDataWriter.
    -->
    <field name="id"             class="java.lang.String"/>
    <field name="name"           class="java.lang.String"/>
    <field name="stock"          class="java.lang.String"/>
    <field name="priceFormatted" class="java.lang.String"/>
    <field name="lowStock"       class="java.lang.String"/>

    <!-- ── TITLE ──────────────────────────────────────────────────── -->
    <title>
        <band height="160">
            <!-- Logo (shown only when logo file exists) -->
            <image onErrorType="Blank" hAlign="Center">
                <reportElement x="0" y="0" width="555" height="60">
                    <printWhenExpression><![CDATA[$P{LOGO_IMAGE} != null && !$P{LOGO_IMAGE}.isEmpty()]]></printWhenExpression>
                </reportElement>
                <imageExpression><![CDATA[$P{LOGO_IMAGE}]]></imageExpression>
            </image>

            <staticText>
                <reportElement x="0" y="60" width="555" height="28"/>
                <textElement textAlignment="Center">
                    <font fontName="DejaVu Sans" size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[VI-PS PHARMA]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="90" width="555" height="20"/>
                <textElement textAlignment="Center"><font fontName="DejaVu Sans" size="12"/></textElement>
                <text><![CDATA[STOCK INVENTORY REPORT]]></text>
            </staticText>

            <!-- Generated date -->
            <textField>
                <reportElement x="0" y="112" width="555" height="16"/>
                <textElement textAlignment="Center"><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA["Generated: " + $P{reportDate}]]></textFieldExpression>
            </textField>

            <!-- Summary stats -->
            <textField>
                <reportElement x="0" y="130" width="277" height="16"/>
                <textElement textAlignment="Left"><font fontName="DejaVu Sans" size="9"/></textElement>
                <textFieldExpression><![CDATA["Total Products: " + $P{totalItems}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="277" y="130" width="278" height="16"/>
                <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["Low Stock Items: " + $P{lowStockCount}]]></textFieldExpression>
            </textField>

            <line><reportElement x="0" y="148" width="555" height="1"/></line>
        </band>
    </title>

    <!-- ── COLUMN HEADER ─────────────────────────────────────────── -->
    <columnHeader>
        <band height="22">
            <staticText>
                <reportElement x="0"   y="2" width="40"  height="18"/>
                <textElement><font fontName="DejaVu Sans" size="10" isBold="true"/></textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="40"  y="2" width="280" height="18"/>
                <textElement><font fontName="DejaVu Sans" size="10" isBold="true"/></textElement>
                <text><![CDATA[MEDICINE NAME]]></text>
            </staticText>
            <staticText>
                <reportElement x="320" y="2" width="90"  height="18"/>
                <textElement textAlignment="Center"><font fontName="DejaVu Sans" size="10" isBold="true"/></textElement>
                <text><![CDATA[STOCK]]></text>
            </staticText>
            <staticText>
                <reportElement x="410" y="2" width="145" height="18"/>
                <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="10" isBold="true"/></textElement>
                <text><![CDATA[PRICE (₱)]]></text>
            </staticText>
            <line><reportElement x="0" y="20" width="555" height="1"/></line>
        </band>
    </columnHeader>

    <!-- ── DETAIL — one row per <medicine> node ──────────────────── -->
    <detail>
        <band height="22">
            <!-- ID -->
            <textField>
                <reportElement x="0"   y="2" width="40"  height="18" style="LowStockStyle"/>
                <textElement><font fontName="DejaVu Sans" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>
            <!-- Name -->
            <textField isStretchWithOverflow="true">
                <reportElement x="40"  y="2" width="280" height="18" style="LowStockStyle"/>
                <textElement><font fontName="DejaVu Sans" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{name}]]></textFieldExpression>
            </textField>
            <!-- Stock  (red + bold when low) -->
            <textField>
                <reportElement x="320" y="2" width="90"  height="18" style="LowStockStyle"/>
                <textElement textAlignment="Center"><font fontName="DejaVu Sans" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{stock}]]></textFieldExpression>
            </textField>
            <!-- Price -->
            <textField>
                <reportElement x="410" y="2" width="145" height="18" style="LowStockStyle"/>
                <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{priceFormatted}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- ── SUMMARY — legend ──────────────────────────────────────── -->
    <summary>
        <band height="40">
            <line><reportElement x="0" y="0" width="555" height="1"/></line>
            <staticText>
                <reportElement x="0" y="8" width="555" height="14"/>
                <textElement><font fontName="DejaVu Sans" size="8"/></textElement>
                <text><![CDATA[* Items displayed in RED have stock below 20 units and require restocking.]]></text>
            </staticText>
        </band>
    </summary>

</jasperReport>
