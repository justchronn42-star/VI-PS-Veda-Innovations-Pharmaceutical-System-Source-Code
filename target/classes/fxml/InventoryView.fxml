<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vips.pharma.controller.InventoryController"
      spacing="16" styleClass="view-pane">
    <padding><Insets top="24" left="24" right="24" bottom="24"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Inventory Management" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <Button text="🖨  Print Stock Report" onAction="#printStockReport" styleClass="btn-outline"/>
        <Button fx:id="btnAddMedicine" text="＋  Add Medicine" onAction="#showAddDialog" styleClass="btn-primary"/>
    </HBox>

    <HBox spacing="24" alignment="CENTER_LEFT"
          style="-fx-background-color:#2c1f5e; -fx-background-radius:6; -fx-padding:10 16 10 16;">
        <Label fx:id="lblTotalItems" text="Items: 0"      style="-fx-text-fill:white; -fx-font-weight:bold;"/>
        <Label fx:id="lblLowStock"   text="Low Stock: 0"  style="-fx-text-fill:#ff8a80; -fx-font-weight:bold;"/>
        <Label fx:id="lblExpired"    text="Expired: 0"    style="-fx-text-fill:#ff6b6b; -fx-font-weight:bold;"/>
    </HBox>

    <TextField fx:id="tfSearch" promptText="🔍  Search inventory…" styleClass="search-field"/>

    <VBox styleClass="white-panel" VBox.vgrow="ALWAYS" spacing="0">
        <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS" styleClass="data-table">
            <columns>
                <TableColumn fx:id="colId"      text="ID"           prefWidth="60"/>
                <TableColumn fx:id="colName"    text="Medicine"     prefWidth="260"/>
                <TableColumn fx:id="colStock"   text="Stock"        prefWidth="90"/>
                <TableColumn fx:id="colPrice"   text="Price (₱)"    prefWidth="120"/>
                <TableColumn fx:id="colExpiry"  text="Expiry Date"  prefWidth="170"/>
                <TableColumn fx:id="colActions" text="Actions"      prefWidth="160"/>
            </columns>
            <placeholder>
                <Label text="No medicines in inventory." style="-fx-text-fill:#888;"/>
            </placeholder>
        </TableView>
    </VBox>
</VBox>
