<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vips.pharma.controller.AuditController"
      spacing="16" styleClass="view-pane">
    <padding><Insets top="24" left="24" right="24" bottom="24"/></padding>

    <Label text="Audit Logs" styleClass="page-title"/>

    <VBox styleClass="white-panel" VBox.vgrow="ALWAYS">
        <TableView fx:id="auditTable" VBox.vgrow="ALWAYS" styleClass="data-table">
            <columns>
                <TableColumn fx:id="colId"       text="#"          prefWidth="50"/>
                <TableColumn fx:id="colAction"   text="Action"     prefWidth="420"/>
                <TableColumn fx:id="colUsername" text="By User"    prefWidth="130"/>
                <TableColumn fx:id="colDateTime" text="Date/Time"  prefWidth="170"/>
            </columns>
            <placeholder>
                <Label text="No audit logs yet." style="-fx-text-fill:#888;"/>
            </placeholder>
        </TableView>
    </VBox>
</VBox>
