<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vips.pharma.controller.ReceiptsController"
      spacing="16" styleClass="view-pane">
    <padding><Insets top="24" left="24" right="24" bottom="24"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Sales History" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <Button text="🖨  Reprint Selected" onAction="#reprintSelected" styleClass="btn-outline"/>
    </HBox>

    <VBox styleClass="white-panel" VBox.vgrow="ALWAYS" spacing="0">
        <TableView fx:id="receiptsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
            <columns>
                <TableColumn fx:id="colId"          text="#"            prefWidth="50"/>
                <TableColumn fx:id="colMed"         text="Items"        prefWidth="240"/>
                <TableColumn fx:id="colQty"         text="Qty"          prefWidth="60"/>
                <TableColumn fx:id="colTotal"       text="Total (₱)"    prefWidth="120"/>
                <TableColumn fx:id="colProcessedBy" text="Processed By" prefWidth="120"/>
                <TableColumn fx:id="colDate"        text="Date/Time"    prefWidth="170"/>
            </columns>
            <placeholder>
                <Label text="No sales recorded yet." style="-fx-text-fill:#888;"/>
            </placeholder>
        </TableView>

        <HBox styleClass="summary-bar" spacing="30" alignment="CENTER_LEFT">
            <padding><Insets top="8" left="12" right="12" bottom="8"/></padding>
            <Label fx:id="lblTotalSales"   text="Total Transactions: 0"/>
            <Label fx:id="lblTotalRevenue" text="Total Revenue: ₱0.00" style="-fx-font-weight:bold;"/>
        </HBox>
    </VBox>
</VBox>
